# Slack tokens (Step 1 se milenge)
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_APP_TOKEN=xapp-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# LLM - Qwen (Alibaba Cloud DashScope) ya OpenAI, jo bhi use kar rahe ho
QWEN_API_KEY=your-qwen-key-here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Agar OpenAI use karna hai to ye uncomment karo aur upar wale comment kardo
# OPENAI_API_KEY=your-openai-key-here
